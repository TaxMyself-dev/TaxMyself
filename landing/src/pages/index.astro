---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import OpenBanking from '../components/OpenBanking.astro';
import Features from '../components/Features.astro';
import BusinessHousehold from '../components/BusinessHousehold.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
	title="KeepInTax - פשוט להיות על זה"
	description="ניהול פיננסי חכם לעסקים ולמשקי בית. חיבור לבנקאות פתוחה, הפקת מסמכים ודוחות במקום אחד."
>
	<Navbar />
	<main>
		<Hero />
		<OpenBanking />
		<Features />
		<BusinessHousehold />
		<FAQ />
		<FinalCTA />
	</main>
	<Footer />
</BaseLayout>
