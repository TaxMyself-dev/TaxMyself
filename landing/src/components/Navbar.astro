---
const loginUrl = import.meta.env.PUBLIC_APP_LOGIN_URL ?? 'https://app.keepintax.co.il/login';
---

<nav class="navbar" aria-label="ניווט ראשי">
	<div class="navbar-inner">
		<div class="navbar-brand-and-links">
			<a href="/" class="navbar-logo" aria-label="KeepInTax - דף הבית">
				<img src="/logo.svg" alt="לוגו KeepInTax" width="39" height="38" />
			</a>
			<div class="navbar-links">
				<a href="#solution">הפתרון</a>
				<a href="#pricing">תמחור</a>
				<a href="#faq">שאלות נפוצות</a>
			</div>
		</div>
		<a href={loginUrl} class="btn navbar-login" target="_blank" rel="noopener noreferrer">התחברות</a>
	</div>
</nav>

<style>
	.navbar {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border-subtle);
	}

	.navbar-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: 100%;
		margin-inline: auto;
		padding-inline-start: 0.75rem;
		padding-inline-end: 1.25rem;
		padding-block: 0.875rem;
		min-width: 0;
	}

	.navbar-brand-and-links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		min-width: 0;
		flex-shrink: 0;
	}

	.navbar-logo {
		flex-shrink: 0;
		text-decoration: none;
	}

	.navbar-logo:hover {
		text-decoration: none;
	}

	.navbar-logo img {
		height: 36px;
		width: auto;
	}

	.navbar-login {
		flex-shrink: 0;
		background-color: var(--color-accent);
		color: var(--color-primary);
	}

	.navbar-login:hover {
		background-color: var(--color-accent);
		opacity: 0.9;
	}

	.navbar-links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.navbar-links a {
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		text-decoration: none;
	}

	.navbar-links a:hover {
		color: var(--color-primary);
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.navbar-links {
			display: none;
		}

		.navbar-brand-and-links {
			gap: 0.75rem;
		}
	}

	@media (max-width: 390px) {
		.navbar-inner {
			gap: 0.75rem;
			padding-inline-start: 0.75rem;
			padding-inline-end: 1rem;
		}

		.navbar-logo img {
			height: 32px;
		}
	}
</style>
