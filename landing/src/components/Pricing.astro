---
import { pricingPlans } from '../data/pricing';
---

<section class="pricing section" id="pricing">
  <div class="container">
    <header class="section-header animate-on-scroll">
      <h2>כמה זה עולה?</h2>
      <p>ללא התחייבות ובלי דמי רישום, בחרו את התוכנית המתאימה לכם</p>
    </header>

    <div class="pricing__grid">
      {pricingPlans.map((plan, i) => (
        <article
          class:list={[
            'pricing-card',
            `animate-on-scroll delay-${i + 1}`,
            plan.featured && 'pricing-card--featured',
            plan.id === 'pro' && 'pricing-card--pro',
          ]}
          aria-label={`תוכנית ${plan.name}`}
        >
          {plan.featured && (
            <div class="pricing-card__badge-row">
              <span class="pricing-card__badge">{plan.featuredLabel}</span>
            </div>
          )}

          <h3 class="pricing-card__name">{plan.name}</h3>
          <p class="pricing-card__subtitle">{plan.subtitle}</p>
          <hr class="pricing-card__divider" />

          <ul class="pricing-card__features" role="list">
            {plan.features.map((f) => (
              <li class:list={['pricing-card__feature', f.included ? 'included' : 'excluded']}>
                <span
                  class:list={[
                    'pricing-card__check',
                    f.included ? 'pricing-card__check--included' : 'pricing-card__check--excluded',
                  ]}
                  aria-hidden="true"
                >
                  {f.included
                    ? <img src="/images/check-V.svg" alt="" width="17" height="14" loading="lazy" />
                    : <img src="/images/X.svg" alt="" width="12" height="13" loading="lazy" />
                  }
                </span>
                <span class="pricing-card__feature-label" aria-label={`${f.label} — ${f.included ? 'כלול' : 'לא כלול'}`}>
                  {f.label}
                </span>
              </li>
            ))}
          </ul>

          <div class="pricing-card__prices">
            {plan.priceLines.length > 1 ? (
              <div class="pricing-card__price-lines-group">
                {plan.priceLines.map((line) => (
                  <div class="pricing-card__price-line">
                    <span class="pricing-card__amount">{line.amount}</span>
                    <span class="pricing-card__price-tail">
                      <span class="pricing-card__currency" aria-label="שקלים חדשים">&#8362;</span>
                      <span class="pricing-card__period">{line.suffix}</span>
                    </span>
                  </div>
                ))}
              </div>
            ) : (
              plan.priceLines.map((line) => (
                <div class="pricing-card__price-line">
                  <span class="pricing-card__amount">{line.amount}</span>
                  <span class="pricing-card__price-tail">
                    <span class="pricing-card__currency" aria-label="שקלים חדשים">&#8362;</span>
                    <span class="pricing-card__period">{line.suffix}</span>
                  </span>
                </div>
              ))
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .pricing-card {
    background: #fff;
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius);
    padding: 3rem 4rem;
    position: relative;
    min-height: 400px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .pricing-card--featured {
    background: var(--color-pricing-featured-bg);
    border-width: 2px;
    transform: scale(1.03);
    box-shadow: var(--shadow-card);
  }

  /* Corner sticker (Figma): top-left, ~10–15° counter-clockwise */
  .pricing-card__badge-row {
    position: absolute;
    top: 3.1rem;
    left: 2.85rem;
    z-index: 2;
    margin: 0;
  }

  .pricing-card__badge {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-pricing-featured-bg);
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    padding: 5px 18px;
    border-radius: 999px;
    white-space: nowrap;
    transform: rotate(-12deg);
    transform-origin: center center;
  }

  .pricing-card__name {
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-primary);
    margin-bottom: 0.2rem;
    line-height: 1.15;
  }

  .pricing-card__subtitle {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: 0;
    line-height: 1.35;
  }

  .pricing-card__divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin-block: 1.25rem;
  }

  .pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pricing-card__feature {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.35;
  }

  .pricing-card__feature.excluded .pricing-card__feature-label {
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  .pricing-card__check {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pricing-card__check img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* check-V.svg native 17×14 */
  .pricing-card__check--included {
    width: 11px;
    height: 11px;
  }

  /* X.svg native 12×13 */
  .pricing-card__check--excluded {
    width: 8px;
    height: 11px;
  }

  /* Featured plan (Basic): icons on white circles — visible on tinted card bg */
  .pricing-card--featured .pricing-card__check--included,
  .pricing-card--featured .pricing-card__check--excluded {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
  }

  .pricing-card--featured .pricing-card__check--included img {
    width: 11px;
    height: 11px;
    max-width: 11px;
    max-height: 11px;
  }

  .pricing-card--featured .pricing-card__check--excluded img {
    width: 9px;
    height: 9px;
    max-width: 9px;
    max-height: 9px;
  }

  .pricing-card__prices {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    margin-top: auto;
  }

  /* Multi-line plans (e.g. Pro): stack lines to inline-start; block sits at flex-end via parent */
  .pricing-card__price-lines-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
  }

  .pricing-card__price-line {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-end;
    justify-content: flex-end;
    gap: 0.15rem 0.35rem;
    max-width: 100%;
  }

  /* ₪ + suffix share a baseline; whole tail aligns to numeral’s bottom edge */
  .pricing-card__price-tail {
    display: inline-flex;
    flex-wrap: nowrap;
    align-items: baseline;
    gap: 0.15rem 0.35rem;
    /* Optical: large Simpler numerals vs smaller meta text */
    padding-bottom: 0.12em;
  }

  .pricing-card__amount {
    font-size: 3.25rem;
    font-weight: 400;
    line-height: 1;
    color: var(--color-primary);
  }

  .pricing-card--pro .pricing-card__amount {
    font-size: 35px;
  }

  /* U+20AA (₪): Simpler lacks this glyph — use system fonts for correct shape */
  .pricing-card__currency {
    font-family: system-ui, 'Segoe UI', 'Helvetica Neue', Arial, 'Noto Sans Hebrew', sans-serif;
    font-size: 2rem;
    font-weight: 400;
    line-height: 1;
    color: var(--color-primary);
    margin-inline-end: 0.05rem;
  }

  .pricing-card--pro .pricing-card__currency {
    font-size: 21px;
  }

  .pricing-card__period {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    line-height: 1.25;
    white-space: normal;
  }

  @media (max-width: 900px) {
    .pricing__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }

    .pricing-card--featured {
      transform: none;
    }
  }
</style>
