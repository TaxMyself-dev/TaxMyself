---
---

<section class="pricing section section-soft" id="pricing" aria-labelledby="pricing-title">
	<div class="container">
		<h2 class="pricing-title" id="pricing-title">תמחור פשוט וברור</h2>
		<p class="pricing-intro">
			תבחרו את רמת השירות שמתאימה לכם — בלי התחייבות מיותרת.
		</p>
		<div class="pricing-grid">
			<div class="card pricing-card">
				<h3 class="pricing-card-title">שימוש להפקת מסמכים בלבד</h3>
				<p class="pricing-card-price">
					<span class="pricing-amount">18</span>
					<span class="pricing-currency">ש"ח</span>
				</p>
			</div>
			<div class="card pricing-card pricing-card-featured">
				<span class="pricing-badge" aria-hidden="true">מומלץ</span>
				<h3 class="pricing-card-title">שימוש בפלטפורמה באופן עצמאי ללא ייצוג</h3>
				<p class="pricing-card-price">
					<span class="pricing-amount">45</span>
					<span class="pricing-currency">ש"ח</span>
				</p>
			</div>
			<div class="card pricing-card">
				<h3 class="pricing-card-title">שימוש עם ייצוג</h3>
				<div class="pricing-card-prices">
					<p class="pricing-card-price-row">
						<span class="pricing-label">עוסק פטור</span>
						<span class="pricing-value">195 ש"ח</span>
					</p>
					<p class="pricing-card-price-row">
						<span class="pricing-label">עוסק מורשה</span>
						<span class="pricing-value">475 ש"ח + מע"מ</span>
					</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.pricing-title {
		text-align: center;
		margin-bottom: 0.5rem;
		font-size: clamp(1.375rem, 3vw, 1.75rem);
	}

	.pricing-intro {
		text-align: center;
		max-inline-size: 32rem;
		margin: 0 auto 2.5rem;
		font-size: clamp(0.9375rem, 2vw, 1rem);
		color: var(--color-text-secondary);
		line-height: 1.55;
	}

	.pricing-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		align-items: stretch;
	}

	.pricing-card {
		margin: 0;
		display: flex;
		flex-direction: column;
		position: relative;
	}

	.pricing-card-featured {
		border: 2px solid var(--color-primary);
		box-shadow: var(--shadow-soft), 0 0 0 1px var(--color-primary);
	}

	.pricing-badge {
		position: absolute;
		top: -0.5rem;
		inset-inline-end: 1rem;
		padding: 0.25rem 0.6rem;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--color-primary);
		background: var(--color-accent);
		border-radius: 999px;
	}

	.pricing-card-title {
		margin: 0 0 1rem;
		font-size: 1.0625rem;
		font-weight: 600;
		color: var(--color-text);
		line-height: 1.35;
	}

	.pricing-card-price {
		margin: 0;
		margin-top: auto;
		display: flex;
		align-items: baseline;
		gap: 0.25rem;
		flex-wrap: wrap;
	}

	.pricing-amount {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--color-text);
		line-height: 1.2;
	}

	.pricing-currency {
		font-size: 1rem;
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.pricing-card-prices {
		margin: 0;
		margin-top: auto;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.pricing-card-price-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.5rem;
		margin: 0;
		font-size: 0.9375rem;
		color: var(--color-text);
	}

	.pricing-label {
		color: var(--color-text-secondary);
	}

	.pricing-value {
		font-weight: 600;
		white-space: nowrap;
	}

	@media (max-width: 768px) {
		.pricing-intro {
			margin-bottom: 2rem;
		}

		.pricing-grid {
			gap: 1.25rem;
		}
	}

	@media (max-width: 700px) {
		.pricing-grid {
			grid-template-columns: 1fr;
			max-inline-size: 22rem;
			margin-inline: auto;
		}

		.pricing-card-featured {
			order: -1;
		}
	}

	@media (max-width: 390px) {
		.pricing-card-title {
			font-size: 1rem;
		}

		.pricing-amount {
			font-size: 1.5rem;
		}

		.pricing-card-price-row {
			font-size: 0.875rem;
		}
	}
</style>
