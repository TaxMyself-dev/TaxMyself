---
import { pricingPlans } from '../data/pricing';
---

<section class="pricing section" id="pricing">
  <div class="container">
    <header class="section-header animate-on-scroll">
      <h2>כמה זה עולה?</h2>
      <p>ללא התחייבות ובלי דמי רישום, בחרו את התוכנית המתאימה לכם</p>
    </header>

    <div class="pricing__grid">
      {pricingPlans.map((plan, i) => (
        <article
          class:list={[
            'pricing-card',
            `animate-on-scroll delay-${i + 1}`,
            plan.featured && 'pricing-card--featured',
          ]}
          aria-label={`תוכנית ${plan.name}`}
        >
          {plan.featured && (
            <div class="pricing-card__badge-row">
              <span class="pricing-card__badge">{plan.featuredLabel}</span>
            </div>
          )}

          <h3 class="pricing-card__name">{plan.name}</h3>
          <p class="pricing-card__subtitle">{plan.subtitle}</p>
          <hr class="pricing-card__divider" />

          <ul class="pricing-card__features" role="list">
            {plan.features.map((f) => (
              <li class:list={['pricing-card__feature', f.included ? 'included' : 'excluded']}>
                <span class="pricing-card__check" aria-hidden="true">
                  {f.included
                    ? <img src="/images/check-included.svg" alt="" width="28" height="28" loading="lazy" />
                    : <img src="/images/check-excluded.svg" alt="" width="28" height="28" loading="lazy" />
                  }
                </span>
                <span class="pricing-card__feature-label" aria-label={`${f.label} — ${f.included ? 'כלול' : 'לא כלול'}`}>
                  {f.label}
                </span>
              </li>
            ))}
          </ul>

          <div class="pricing-card__price">
            <span class="pricing-card__amount">{plan.price}</span>
            <abbr class="pricing-card__currency" title="שקלים חדשים">₪</abbr>
            <span class="pricing-card__period">{plan.priceSuffix}</span>
          </div>

          {plan.priceNote && (
            <p class="pricing-card__price-note">{plan.priceNote}</p>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .pricing-card {
    background: #fff;
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    position: relative;
  }

  .pricing-card--featured {
    background: var(--color-pricing-featured-bg);
    border-width: 2px;
    transform: scale(1.03);
    box-shadow: var(--shadow-card);
  }

  .pricing-card__badge-row {
    text-align: center;
    margin: 0 0 0.65rem;
  }

  .pricing-card__badge {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-text-white);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 5px 18px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .pricing-card__name {
    font-size: 1.75rem;
    font-weight: 900;
    text-align: center;
    color: var(--color-primary);
    margin-bottom: 0.2rem;
    line-height: 1.15;
  }

  .pricing-card__subtitle {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-align: center;
    margin-bottom: 0;
    line-height: 1.35;
  }

  .pricing-card__divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin-block: 1.25rem;
  }

  .pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pricing-card__feature {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.35;
  }

  .pricing-card__feature.excluded .pricing-card__feature-label {
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  .pricing-card__check {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pricing-card__price {
    display: flex;
    align-items: baseline;
    gap: 0.15rem 0.35rem;
    flex-wrap: wrap;
  }

  .pricing-card__amount {
    font-size: 3.25rem;
    font-weight: 900;
    line-height: 1;
    color: var(--color-primary);
  }

  /* NIS glyph sized to match Figma relative to numerals (Simpler Black) */
  .pricing-card__currency {
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
    color: var(--color-primary);
    text-decoration: none;
    margin-inline-end: 0.05rem;
    translate: 0 0.06em;
  }

  .pricing-card__period {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    flex-basis: 100%;
    margin-top: 0.15rem;
  }

  .pricing-card__price-note {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    margin-top: 0.4rem;
  }

  @media (max-width: 900px) {
    .pricing__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-inline: auto;
    }

    .pricing-card--featured {
      transform: none;
    }
  }
</style>
