---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <a href="/" aria-label="KeepInTax - דף הבית">
      <img src="/logo.svg" alt="KeepInTax" width="136" height="26" loading="lazy" />
    </a>
    <p class="footer__copy">כל הזכויות שמורות לKeepInTax {year}</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: var(--color-text-white);
    padding-block: 1.75rem;
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer__copy {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  @media (max-width: 600px) {
    .footer__inner {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
