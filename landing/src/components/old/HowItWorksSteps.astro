---
const registerUrl = import.meta.env.PUBLIC_APP_REGISTER_URL ?? 'https://app.keepintax.co.il/register';

const steps = [
	{
		number: '1️⃣',
		title: 'נרשמים ללא עלות',
	},
	{
		number: '2️⃣',
		title: 'מחברים את חשבונות הבנק והאשראי',
	},
	{
		number: '3️⃣',
		title: 'מגדירים מה עסקי ומה פרטי',
	},
	{
		number: '4️⃣',
		title: 'מסווגים בקליק',
	},
	{
		number: '5️⃣',
		title: 'ואת השאר אנחנו עושים בשבילכם',
	},
];
---

<section class="how-steps section" id="how-it-works" aria-labelledby="how-steps-title">
	<div class="container">
		<div class="how-steps-cta-wrap">
			<a
				href={registerUrl}
				class="btn how-steps-cta"
				target="_blank"
				rel="noopener noreferrer"
			>
				להרשמה חינם
			</a>
		</div>
		<h2 class="how-steps-title" id="how-steps-title">איך זה עובד?</h2>
		<ol class="how-steps-list">
			{steps.map((step) => (
				<li class="card how-steps-item">
					<span class="how-steps-number" aria-hidden="true">{step.number}</span>
					<div class="how-steps-content">
						<h3 class="how-steps-item-title">{step.title}</h3>
						<p class="how-steps-item-desc">{step.desc}</p>
					</div>
				</li>
			))}
		</ol>
	</div>
</section>

<style>
	.how-steps {
		padding-block-start: 0;
	}

	.how-steps-cta-wrap {
		display: flex;
		justify-content: center;
		margin-bottom: 1.5rem;
	}

	.how-steps-cta {
		background-color: var(--color-accent);
		color: var(--color-primary);
		text-decoration: none;
	}

	.how-steps-cta:hover {
		background-color: var(--color-accent);
		color: var(--color-primary);
		opacity: 0.9;
		text-decoration: none;
	}

	.how-steps-title {
		text-align: center;
		margin-bottom: 2rem;
		font-size: clamp(1.375rem, 3vw, 1.75rem);
	}

	.how-steps-list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		max-inline-size: 36rem;
		margin-inline: auto;
	}

	.how-steps-item {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		margin: 0;
	}

	.how-steps-number {
		flex-shrink: 0;
		font-size: 1.5rem;
		line-height: 1;
	}

	.how-steps-content {
		min-width: 0;
	}

	.how-steps-item-title {
		margin: 0 0 0.25rem;
		font-size: 1.0625rem;
		font-weight: 600;
		color: var(--color-text);
	}

	.how-steps-item-desc {
		margin: 0;
		font-size: 0.9375rem;
		color: var(--color-text-secondary);
		line-height: 1.5;
	}

	@media (max-width: 768px) {
		.how-steps-title {
			margin-bottom: 1.5rem;
		}
	}

	@media (max-width: 390px) {
		.how-steps-cta-wrap {
			margin-bottom: 1.25rem;
		}

		.how-steps-cta {
			width: 100%;
		}

		.how-steps-item {
			gap: 0.75rem;
		}

		.how-steps-number {
			font-size: 1.25rem;
		}

		.how-steps-item-title {
			font-size: 1rem;
		}

		.how-steps-item-desc {
			font-size: 0.875rem;
		}
	}
</style>
