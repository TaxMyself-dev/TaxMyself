---
const registerUrl = import.meta.env.PUBLIC_APP_REGISTER_URL ?? '#';
---

<section class="hero" id="hero" aria-labelledby="hero-headline">
  <div class="container hero__content">
    <div class="hero__badge">
      <span>הצטרפו למשתמשים החדשים</span>
      <span class="hero__avatars" aria-hidden="true">
        <img
          src="/images/user-logo-1.svg"
          alt=""
          width="28"
          height="28"
          loading="lazy"
          class="hero__avatar"
        />
        <img
          src="/images/user-logo-2.svg"
          alt=""
          width="28"
          height="28"
          loading="lazy"
          class="hero__avatar"
        />
        <img
          src="/images/user-logo-3.svg"
          alt=""
          width="28"
          height="28"
          loading="lazy"
          class="hero__avatar"
        />
      </span>
    </div>

    <h1 id="hero-headline" class="hero__headline">
      להרוויח זמן-<br class="hero__headline-break" aria-hidden="true" /> לחסוך כסף
    </h1>
    <p class="hero__sub">ניהול פיננסי חכם לעסק ולבית</p>

    <div class="hero__ctas">
      <a href="#how-it-works" class="btn btn-secondary">עוד פרטים</a>
      <a href={registerUrl} class="btn btn-primary">הרשמה ←</a>
    </div>
  </div>

  <div class="hero__image-area">
    <div class="hero__phone-wrap">
      <img
        src="/images/hero-phone.png"
        alt="ממשק האפליקציה של KeepInTax המציג ניהול פיננסי חכם"
        width="826"
        height="820"
        fetchpriority="high"
        class="hero__phone"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 786px;
    display: flex;
    flex-direction: column;
    background-image: url(/images/hero-wave.svg);
    background-color: var(--color-accent);
    background-repeat: no-repeat;
    /* Height = section height, width follows aspect ratio — sides clip (overflow: hidden) */
    background-size: auto 100%;
    background-position: center bottom;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-top: 100px;
    padding-bottom: 2rem;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid #ebebeb;
    border-radius: 999px;
    padding: 6px 18px 6px 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #1a2641;
    margin-bottom: 1.5rem;
  }

  .hero__avatars {
    display: flex;
  }

  .hero__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid #fff;
    display: block;
    object-fit: cover;
    flex-shrink: 0;
  }

  .hero__avatar + .hero__avatar {
    margin-inline-start: -10px;
  }

  .hero__headline {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    line-height: 1.15;
  }

  .hero__headline-break {
    display: none;
  }

  .hero__sub {
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    font-weight: 400;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Phone + bubbles ── */
  .hero__image-area {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    margin-top: auto;
  }

  .hero__phone-wrap {
    position: relative;
    width: 413px;
  }

  .hero__phone {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .hero {
      min-height: unset;
    }

    .hero__headline-break {
      display: block;
    }

    .hero__content {
      padding-top: 80px;
    }

    .hero__image-area {
      padding-inline: 1rem;
      padding-bottom: 0;
    }

    .hero__phone-wrap {
      width: 100%;
      max-width: 360px;
    }
  }
</style>
