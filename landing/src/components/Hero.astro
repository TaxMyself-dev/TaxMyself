---
const registerUrl = import.meta.env.PUBLIC_APP_REGISTER_URL ?? '#';

const bubbles = [
  {
    n: 1,
    src: '/images/bubble-1.svg',
    text: 'לא יודעים לאן הכסף הולך כל חודש?',
    light: true,
    flip: false,
  },
  {
    n: 2,
    src: '/images/bubble-2.svg',
    text: 'שולחים מסמכים לרואה חשבון אבל לא יודעים מה נכנס לדו״ח?',
    light: true,
    flip: true,
  },
  {
    n: 3,
    src: '/images/bubble-3.svg',
    text: 'נמאס לרדוף אחרי חשבוניות?',
    light: false,
    flip: false,
  },
  {
    n: 4,
    src: '/images/bubble-4.svg',
    text: 'הוצאות הבית והעסק מתערבבות?',
    light: false,
    flip: true,
  },
];
---

<section class="hero" id="hero" aria-labelledby="hero-headline">
  <div class="hero__bg" aria-hidden="true">
    <img src="/images/hero-wave.svg" alt="" class="hero__wave" />
  </div>

  <div class="container hero__content">
    <div class="hero__badge">
      <span class="hero__avatars" aria-hidden="true">
        <span class="hero__avatar"></span>
        <span class="hero__avatar"></span>
        <span class="hero__avatar"></span>
      </span>
      <span>מצטרפים חדשים</span>
    </div>

    <h1 id="hero-headline" class="hero__headline">להרוויח זמן- לחסוך כסף</h1>
    <p class="hero__sub">ניהול פיננסי חכם לעסק ולבית</p>

    <div class="hero__ctas">
      <a href={registerUrl} class="btn btn-primary">הרשמה בחינם &lt;</a>
      <a href="#how-it-works" class="btn btn-secondary">עוד פרטים</a>
    </div>
  </div>

  <div class="hero__image-area">
    <div class="hero__phone-wrap">
      <img
        src="/images/hero-phone.png"
        alt="ממשק האפליקציה של KeepInTax המציג ניהול פיננסי חכם"
        width="826"
        height="820"
        fetchpriority="high"
        class="hero__phone"
      />

      {bubbles.map(b => (
        <div
          class={`hero__bubble hero__bubble--${b.n} bubble-float${b.n > 1 ? ` delay-${b.n - 1}` : ''}`}
          aria-hidden="true"
        >
          <img
            src={b.src}
            alt=""
            class={`hero__bubble-shape${b.flip ? ' hero__bubble-shape--flip' : ''}`}
          />
          <p class={`hero__bubble-text${b.light ? '' : ' hero__bubble-text--dark'}`}>
            {b.text}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 786px;
    display: flex;
    flex-direction: column;
  }

  /* Solid lime background confirmed from Figma node 2:2450 */
  .hero__bg {
    position: absolute;
    inset: 0;
    background-color: var(--color-accent);
    z-index: 0;
  }

  .hero__wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-top: 100px;
    padding-bottom: 2rem;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid #ebebeb;
    border-radius: 999px;
    padding: 6px 18px 6px 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #1a2641;
    margin-bottom: 1.5rem;
  }

  .hero__avatars {
    display: flex;
  }

  .hero__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid #fff;
    display: block;
  }

  .hero__avatar + .hero__avatar {
    margin-inline-start: -10px;
  }

  .hero__headline {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    line-height: 1.15;
  }

  .hero__sub {
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    font-weight: 400;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Phone + bubbles ── */
  .hero__image-area {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    margin-top: auto;
  }

  .hero__phone-wrap {
    position: relative;
    width: 413px;
  }

  .hero__phone {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Bubble composite ── */
  .hero__bubble {
    position: absolute;
    pointer-events: none;
  }

  .hero__bubble-shape {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Mirror the shape so the tail points left (toward phone from the right side) */
  .hero__bubble-shape--flip {
    transform: scaleX(-1);
  }

  .hero__bubble-text {
    position: absolute;
    /* Stay within the rectangular body — bubble tail occupies bottom ~28% */
    inset: 10% 10% 28% 10%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0;
    color: #1a2641;
  }

  .hero__bubble-text--dark {
    color: #ebfd71;
  }

  /* Individual bubble widths and positions — relative to .hero__phone-wrap */
  .hero__bubble--1 {
    width: 210px;
    bottom: 55%;
    inset-inline-end: 100%;
  }

  .hero__bubble--2 {
    width: 260px;
    top: 30%;
    inset-inline-start: 100%;
  }

  /* bubble-2 text inset adjusted for its shallower tail depth (~26% vs 28%) */
  .hero__bubble--2 .hero__bubble-text {
    inset-block-end: 26%;
  }

  .hero__bubble--3 {
    width: 180px;
    top: 10%;
    inset-inline-end: 95%;
  }

  .hero__bubble--4 {
    width: 180px;
    bottom: 40%;
    inset-inline-start: 98%;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .hero {
      min-height: unset;
    }

    .hero__content {
      padding-top: 80px;
    }

    .hero__image-area {
      padding-inline: 1rem;
      padding-bottom: 0;
    }

    .hero__phone-wrap {
      width: 100%;
      max-width: 360px;
    }

    .hero__bubble {
      display: none;
    }
  }
</style>
