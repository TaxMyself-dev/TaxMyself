---
---

<section class="hero section" aria-labelledby="hero-heading">
	<div class="container hero-inner">
		<div class="hero-content">
			<a href="/" class="hero-logo" aria-label="KeepInTax - דף הבית">
				<img src="/logo.svg" alt="לוגו KeepInTax" width="48" height="47" />
			</a>
			<h1 class="hero-headline" id="hero-heading">פשוט להיות על זה.</h1>
			<hr class="hero-divider" aria-hidden="true" />
			<p class="hero-badge">ניהול פיננסי חכם לעסקים ולמשקי בית</p>
		</div>
	</div>
</section>

<style>
	.hero {
		padding-block: 4rem 1.5rem;
	}

	.hero-inner {
		display: flex;
		justify-content: center;
	}

	.hero-content {
		max-inline-size: 32rem;
		text-align: center;
	}

	.hero-logo {
		display: inline-block;
		margin: 0 0 1rem;
		text-decoration: none;
	}

	.hero-logo:hover {
		text-decoration: none;
	}

	.hero-logo img {
		display: block;
		height: 52px;
		width: auto;
	}

	.hero-headline {
		margin: 0;
		font-size: clamp(1.75rem, 4vw, 2.75rem);
		font-weight: 700;
		line-height: 1.2;
		color: var(--color-text);
	}

	.hero-divider {
		display: block;
		width: 100%;
		height: 4px;
		margin: 0.75rem 0 0.5rem;
		padding: 0;
		border: none;
		background: var(--color-accent);
		opacity: 0.9;
		border-radius: 3px;
	}

	.hero-badge {
		display: inline-block;
		margin: 0.5rem 0 0;
		padding: 0.35rem 0.75rem;
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--color-primary);
		background: var(--color-bg-soft);
		border-radius: 999px;
	}

	@media (max-width: 768px) {
		.hero {
			padding-block: 2.5rem 1.25rem;
		}

		.hero-logo img {
			height: 44px;
		}

		.hero-divider {
			margin: 0.625rem 0 0.375rem;
			height: 2px;
		}

		.hero-badge {
			margin: 0.375rem 0 0;
		}
	}

	@media (max-width: 390px) {
		.hero {
			padding-block: 2rem 1rem;
		}

		.hero-logo img {
			height: 40px;
		}

		.hero-divider {
			margin: 0.5rem 0 0.375rem;
		}

		.hero-badge {
			margin: 0.375rem 0 0;
		}
	}
</style>
